# ===================================================================
# EYK Mueblería · Variables de entorno
# Copia este archivo a .env.local y rellena con tus valores.
# ===================================================================

# Supabase
# - Public client (forms, browser reads): URL + publishable/anon key
# - Admin server (uploads, content edits, product CRUD): service_role key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
# o, alternativamente:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxx

# Server-only — NO usar prefijo NEXT_PUBLIC_. Da bypass de RLS.
# Obtener en: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...service_role...

# Contacto · WhatsApp en formato internacional sin "+" (ej: 50688887777)
NEXT_PUBLIC_WHATSAPP=50688887777
NEXT_PUBLIC_PHONE=+506 8888 7777
NEXT_PUBLIC_EMAIL=ventas@eykmuebleria.com
NEXT_PUBLIC_INSTAGRAM=eykmuebleria

# Admin panel (contraseña hardcodeada — cambiar antes de deploy)
ADMIN_PASSWORD=admin1234
ADMIN_SECRET=eyk-secret-cambiame-2025
